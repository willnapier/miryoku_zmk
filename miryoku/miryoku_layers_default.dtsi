/* miryoku/miryoku_layers_default.dtsi */

/* Colemak-DH alphas, default thumb keys   */  MIRYOKU_X(BASE , "Base")   \
/* Symbols                                  */  MIRYOKU_X(SYM  , "Sym")    \
/* Numbers & fn row                         */  MIRYOKU_X(NUM  , "Num")    \
/* Navigation                               */  MIRYOKU_X(NAV  , "Nav")    \
/* Media / BT / system                      */  MIRYOKU_X(MEDIA, "Media")  \
/* Dedicated mouse layer                    */  MIRYOKU_X(MOUSE, "Mouse")  \
/* F-keys & misc.                           */  MIRYOKU_X(FUN  , "Fun")
